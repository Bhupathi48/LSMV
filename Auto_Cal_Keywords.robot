Get Data From Excel Sheet for Auto-calc Pulse-CDDR72
    [Documentation]    Validate Pulse-CDDR72
    [Arguments]    ${sheet_name}
    ${project_folder}=    Set Variable    ${EXECDIR}${/}Resource${/}TestData_Excels${/}
    ${excel_file}=    Set Variable    ${project_folder}LSMV_TestData.xlsx
    ${sheet_name}=    Set Variable    ${sheet_name}
    ${data}=    Connect And Read Data From Excel Sheet    ${excel_file}    ${sheet_name}
    Log     ${data}
     ${row_index}=    Set Variable    1
    FOR    ${row}    IN    @{data}
        Set Test Variable    ${Json_File_value}    ${row['Json File']}
        Set Test Variable    ${product_flag_value}    ${row['Product Flag']}
        Set Test Variable    ${product_type_value}    ${row['Product Type']}
        Set Test Variable    ${reporter_qualification_value}    ${row['Reporter_1_qualification']}
        Set Test Variable    ${reporter_one_person_type_value}    ${row['Reporter_1_Person Type']}
        Set Test Variable    ${validation}      ${row['Validation']}
        
        # Only read Reporter 2 and 3 values for Check 7, 8, 9
        IF    '${row['Validation']}' in ['Check 7', 'Check 8', 'Check 9']
            Set Test Variable    ${reporter_two_qualification_value}    ${row['Reporter_2_qualification']}
            Set Test Variable    ${reporter_two_person_type_value}    ${row['Reporter_2_Person Type']}
            Set Test Variable    ${reporter_three_qualification_value}    ${row['Reporter_3_qualification']}
            Set Test Variable    ${reporter_three_person_type_value}    ${row['Reporter_3_Person Type']}
        END
        
        IF    '${validation}' == 'Check 1' or '${validation}' == 'Check 7'
            Import AER data and retrieve RCT number   ${Json_File_value}  
            Search for AER    ${rct_number_json}
            Wait for Element display
            Wait Until Element Is Not Visible    ${wvar('search_loading_img_xpath')}    timeout=90
            Wait For General Tab
            Take Screenshot    selenium        
            # common element highlight while importing xml
            clasify the RCT to retrieve the AER number
            Wait for Element display            
            Move RCT Stage from Intake and Assignment to Target Stage    ${rct_number_json}    Full Data Entry
            Wait for Element display
            Highlight Workflow Status
            Press Ctrl E Keyboard Shortcut
        END
        
        IF    '${validation}' == 'Check 1'
            # Perform Product Reporter Validation for CDDR72
            ${validator_result}    ${validator_error}=    Run Keyword And Ignore Error    Validate CDDR72
            IF    '${validator_result}' == 'FAIL'
                Take Screenshot    Fail
            END
        END
        
        IF    '${validation}' in ['Check 2', 'Check 3', 'Check 4', 'Check 5', 'Check 6']
            ${validator_result}    ${validator_error}=    Run Keyword And Ignore Error    Validate CDDR72
            IF    '${validator_result}' == 'FAIL'
                Take Screenshot    Fail
            END
        END
        
        IF    '${validation}' in ['Check 7', 'Check 8', 'Check 9']
            ${validator_result}    ${validator_error}=    Run Keyword And Ignore Error    Validate CDDR72 Multiple Reporters
            IF    '${validator_result}' == 'FAIL'
                Take Screenshot    Fail
            END
        END
        
        ${Output_excel}=    Set Variable    ${EXECDIR}/Output/${sheet_name}.xlsx
        Update Cell By Excel Row    ${EXECDIR}/Output/${sheet_name}.xlsx    ${sheet_name}    ${row_index}    RCT No    ${RCT_No}
        Update Cell By Excel Row    ${Output_excel}    ${sheet_name}    ${row_index}    Actual Test Result    ${validator_result}
        ${row_index}=    Evaluate    ${row_index} + 1
    END
    Log file to report     ${Output_excel}
    ${Test_Result}     ${Test_status}=    Get Actual Test Results    ${Output_excel}
    Run Keyword If    '${Test_status}' == 'True'
    ...    Log To Console    Test Pass.
    ...  ELSE
    ...    Fail    Test failed. Failure Test Data ${Test_Result}
    Run Keyword If    '${test_status}' == 'Fail'    Fail    Test failed due to workflow status mismatch.  

