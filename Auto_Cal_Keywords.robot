Get Data From Excel Sheet Autocalc PULSE-CDDR83
    [Documentation]    Validate term highlighted values
    [Arguments]    ${merged_dict}
    Log    Dict: ${merged_dict}
    ${project_folder}=    Set Variable    ${EXECDIR}${/}Resource${/}TestData_Excels${/}
    ${excel_file}=    Set Variable    ${project_folder}LSMV_TestData.xlsx
    ${sheet_name}=    Set Variable    ${scenario_sheet_name}
    ${data}=    Connect And Read Data From Excel Sheet    ${excel_file}    ${sheet_name}
    Log to Console   ${data}
    ${row_index}=    Set Variable    1
    FOR    ${row}    IN    @{data}
        Log    Event seriousness: ${row['Event Seriousness']} | Term Highlighted: ${row['Term Highlighted']} | Workflow: ${row['Workflow']}
        ${Event_seriousness}=    Set Variable    ${row['Event Seriousness']}
        ${expected_highlighted_term}=    Set Variable    ${row['Term Highlighted']}
        @{workflow}=    Split String    ${row['Workflow']}
        ${workflow_type}=   Get From List   ${workflow}    0
        IF   '${Event_seriousness}' == 'Yes'
            ${serious_yes}=    Get From Dictionary   ${merged_dict}   ${workflow_type}_serious_yes
            ${Status_yes}=    Run Keyword And Return Status    Should Be Equal As Strings    ${serious_yes}    ${expected_highlighted_term}
            IF   '${Status_yes}' == 'True'
                ${result}=  Set variable    PASS
            ELSE
                ${result}=  Set variable    FAIL
            END
        ELSE IF    '${Event_seriousness}' == 'No'
            ${serious_no}=     Get From Dictionary   ${merged_dict}    ${workflow_type}_serious_no
            ${Status_no}=    Run Keyword And Return Status    Should Be Equal As Strings    ${serious_no}    ${expected_highlighted_term}
            IF   '${Status_no}' == 'True'
                ${result}=  Set variable    PASS
            ELSE
                ${result}=  Set variable    FAIL
            END
        END
        Log Test Iteration Result To PDF    ${workflow_type} Review    ${result}
        ${Output_excel}=    Set Variable    ${EXECDIR}/Output/${sheet_name}.xlsx
        Update Cell By Excel Row   ${Output_excel}    ${sheet_name}    ${row_index}    RCT No    ${rct_number_json} 
        Update Cell By Excel Row   ${Output_excel}    ${sheet_name}    ${row_index}    Actual Test Result    ${result}
        ${row_index}=    Evaluate    ${row_index} + 1

    END
    # Log file to report     ${Output_excel}
    # ${Test_Result}     ${Test_status}=    Get Actual Test Results    ${Output_excel}
    # Run Keyword If    '${Test_status}' == 'True'
    # ...    Log To Console    Test Pass.
    # ...  ELSE
    # ...    Fail    Test failed. Failure Test Data ${Test_Result}
    # Run Keyword If    '${test_status}' == 'Fail'    Fail    Test failed due to Term Highlight mismatch.
    Set Test Variable    ${Output_excel}    
     Validate Test Results    ${Output_excel}

