        Set Test Variable    ${Case_classification_value}    ${row['Case classification']}               
        Set Test Variable    ${Event_Received_Date_value}    ${row['Event Received Date']}               
        Set Test Variable    ${Workflow_Save_value}    ${row['Workflow_Save']}               
        
        IF    '${Workflow_Save_value}' == 'Intake and Assessment' and '${Case_classification_value}' == 'Follow up'
