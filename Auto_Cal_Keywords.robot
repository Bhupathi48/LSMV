    Log to Console  ${data}
    ${Data_count}=    Get Length    ${data}

    # This loop will Create the new reporter and assign person type and qualification
    FOR    ${row}    IN    @{data}
        Log    Start Date Format: ${row['Reporter No']} | Person Type: ${row['Person Type']} | Qualification: ${row['Qualification']} | Primary Source For Regulatory Purposes: ${row['Primary Source For Regulatory Purposes']} | Primary Reporter: ${row['Primary Reporter']}
        Set Test Variable    ${Reporter_No_value}    ${row['Reporter No']}
        Set Test Variable    ${Person_Type_value}      ${row['Person Type']}
        Set Test Variable    ${Qualification_value}            ${row['Qualification']}
        Set Test Variable    ${Primary_Source_value}      ${row['Primary Source For Regulatory Purposes']}
        Set Test Variable    ${Primary_Reporter_value}               ${row['Primary Reporter']}
        Click Element Custom    ${wvar('reporter_tab_xpath')}
        Auto-calc PULSE-CDDR30    ${Reporter_No_value}    ${Person_Type_value}   ${Qualification_value}   ${Primary_Source_value}      ${Primary_Reporter_value}     ${Data_count}
    END
    Click Element Custom    ${wvar('save_btn_xpath')}
    Wait Until Element Is Visible    ${wvar('validation_confirm_ok_button_xpath')}    timeout=90
    Click Element Custom    ${wvar('validation_confirm_ok_button_xpath')}
    Click Element Custom    ${wvar('parent_tab_xpath')}
    Click Element Custom    ${wvar('reporter_tab_xpath')}
    ${row_index}=    Set Variable    1
    # This loop will Validate Radio button and Checkbox
    FOR    ${row}    IN    @{data}
        Log    Start Date Format: ${row['Reporter No']} | Person Type: ${row['Person Type']} | Qualification: ${row['Qualification']} | Primary Source For Regulatory Purposes: ${row['Primary Source For Regulatory Purposes']} | Primary Reporter: ${row['Primary Reporter']}
        Set Test Variable    ${Reporter_No_value}    ${row['Reporter No']}
        Set Test Variable    ${Person_Type_value}      ${row['Person Type']}
        Set Test Variable    ${Qualification_value}            ${row['Qualification']}
        Set Test Variable    ${Primary_Source_value}      ${row['Primary Source For Regulatory Purposes']}
        Set Test Variable    ${Primary_Reporter_value}               ${row['Primary Reporter']}
        Click Element Custom    ${wvar('reporter_tab_xpath')}
        Wait for Element display
        Highlight Workflow Status
        ${reporter_tab}=    Replace String     ${wvar('reporter_tab_nester_tab_xpath')}     replace    ${Reporter_No_value}.${SPACE}Reporter
        ${status}=    Run Keyword And Return Status    Wait Until Element Is Visible    ${reporter_tab}    5s
        ${status1}=    Run Keyword And Return Status    Wait Until Element Is Enabled    ${reporter_tab}    5s
        IF    '${status}' == 'False' or '${status1}' == 'False' 
            Click Element Custom    ${wvar('reporter_next_btn_xpath')}
        END     
        ${status}=    Run Keyword And Return Status     Click Element Custom    ${reporter_tab}      
        IF    '${status}' == 'False'
            Click Element Custom    ${wvar('reporter_next_btn_xpath')}
            Click Element Custom    ${reporter_tab}
        END
        Click Element Custom    ${wvar('reporter_tab_xpath')}
        ${validator_result1}    ${validator_error1}=    Run Keyword And Ignore Error    Validate Primary Source For Reached Radio Button Check     ${Primary_Source_value}
        ${validator_result2}    ${validator_error2}=    Run Keyword And Ignore Error    Validate Primary Reporter Checkbox       ${Primary_Reporter_value}
        IF    '${validator_result1}' == 'PASS' and '${validator_result2}' == 'PASS'
            ${validator_result}=    Set Variable    PASS
        ELSE
            ${validator_result}=    Set Variable    FAIL
        END
        ${Output_excel}=    Set Variable    ${EXECDIR}/Output/${sheet_name}.xlsx
        Update Cell By Excel Row    ${EXECDIR}/Output/${sheet_name}.xlsx    ${sheet_name}    ${row_index}    RCT No    ${RCT_No}
        Update Cell By Excel Row    ${Output_excel}    ${sheet_name}    ${row_index}    Actual Test Result    ${validator_result}
        ${row_index}=    Evaluate    ${row_index} + 1        
        Log    ${validator_result}

    END
    Set Test Variable    ${Output_excel}    
    Validate Test Results    ${Output_excel}

