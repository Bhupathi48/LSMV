Validate Labeling SUSAR Checkbox Is Checked
    [Documentation]    Validate that the Labeling SUSAR Checkbox is checked
    [Arguments]    ${labeling_ctry}    ${SUSAR_status}
    Log    ${SUSAR_status}
    IF    '${SUSAR_status}' == 'Checked'
        ${SUSAR_status}=    Set Variable    True
    ELSE
        IF    '${SUSAR_status}' == 'Unchecked'
            ${SUSAR_status}=    Set Variable    False
        END
    END
    Log    Validating Labeling SUSAR Checkbox for ${labeling_ctry} with status ${SUSAR_status} 
    ${count}=     Set Variable    1
    ${table_rows_elements}=     Get WebElements    ${wvar('labeling_table_rows_xpath')}
    FOR    ${rows}    IN    @{table_rows_elements}
        ${count}=    Convert To String    ${count}    
        ${act_labeling_ctry_xpath}=    Replace String    ${wvar('labeling_ctry_rows_xpath')}    replace    ${count}
        ${act_labeling_ctry}=    Get Element Attribute    ${act_labeling_ctry_xpath}    aria-label        
        Log    ${act_labeling_ctry}
        IF    '${act_labeling_ctry}' == '${labeling_ctry}'
            ${act_labeling_susar_checkbox_xpath}=    Replace String    ${wvar('labeling_susar_checkbox_xpath')}    replace    ${count}
            ${act_labeling_highlight_susar_checkbox_xpath}=    Replace String    ${wvar('labeling_highlight_susar_checkbox_xpath')}    replace    ${count}
            Highlight WebElement    ${act_labeling_highlight_susar_checkbox_xpath}
            ${susar_checkbox_status}=    Get Element Attribute    ${act_labeling_susar_checkbox_xpath}    aria-checked
            ${status}=    Run Keyword And Return Status    Should Be Equal As Strings    ${susar_checkbox_status}    ${SUSAR_status}    ignore_case=True
            Run Keyword If    '${status}' == 'True'
            ...    Log   Validation Success. Labeling SUSAR Checkbox is checked.    console=True
            ...  ELSE
            ...    Fail    Validation Fail. Labeling SUSAR Checkbox is not checked.
        END
        ${count}=    Evaluate    ${count} + 1            
    END

