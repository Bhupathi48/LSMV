Validate Pulse-CDDR-18 For Final Review
    [Documentation]     Validate Pulse-CDDR-18 For Final Review
    ${project_folder}=    Set Variable    ${EXECDIR}${/}Resource${/}TestData_Excels${/}
    ${excel_file}=    Set Variable    ${project_folder}LSMV_TestData.xlsx
    ${sheet_name}=    Set Variable    ${scenario_sheet_name}
    ${data}=    Connect And Read Data From Excel Sheet    ${excel_file}    ${sheet_name}
    Log to Console  ${data}
    ${row_index}=    Set Variable    1
    FOR    ${row}    IN    @{data}        
        Set Test Variable    ${Title_value}    ${row['Title']}
        Set Test Variable    ${First_Name_value}      ${row['First Name']}   
        Set Test Variable    ${Middle_Name_value}      ${row['Middle Name']}  
        Set Test Variable    ${Last_Name_value}      ${row['Last Name']}
        Set Test Variable    ${Street_value}      ${row['Street']}
        Set Test Variable    ${City_value}      ${row['City']}
        Set Test Variable    ${State_value}      ${row['State']}           
        Set Test Variable    ${County_value}      ${row['County']}           
        Set Test Variable    ${Postal_Code_value}      ${row['Postal Code']}           
        Set Test Variable    ${Country_value}      ${row['Country']}           
        Set Test Variable    ${Telephone_value}      ${row['Telephone']}
        Set Test Variable    ${Telephone_Residence_value}      ${row['Telephone(Residence)']}
        Set Test Variable    ${Email_Id_value}      ${row['Email Id']}
        Set Test Variable    ${Qualification_value}      ${row['Qualification']} 
        Set Test Variable    ${Stage_value}      ${row['Stage']} 
        IF    '${Stage_value}' == 'Intake And Assessment'
            ${validator_result}    ${validator_error}=    Run Keyword And Ignore Error    Validate Auto-calc PULSE-CDDR18 In Intake and Assignment Stage    ${Title_value}    ${First_Name_value}    ${Middle_Name_value}    ${Last_Name_value}    ${Street_value}    ${City_value}    ${State_value}    ${County_value}    ${Postal_Code_value}    ${Country_value}    ${Telephone_value}    ${Telephone_Residence_value}    ${Email_Id_value}    ${Qualification_value}    ${Stage_value}
            IF    '${validator_result}' == 'FAIL'
                Take Screenshot    Fail
            END
        END                       
        IF    '${Stage_value}' == 'Final Review'
            User navigated to the Case Listing module under Case Management               
            ${validator_result}    ${validator_error}=    Run Keyword And Ignore Error    Auto-calc PULSE-CDDR18    ${Title_value}    ${First_Name_value}    ${Middle_Name_value}    ${Last_Name_value}    ${Street_value}    ${City_value}    ${State_value}    ${County_value}    ${Postal_Code_value}    ${Country_value}    ${Telephone_value}    ${Telephone_Residence_value}    ${Email_Id_value}    ${Qualification_value}    ${Stage_value}
            IF    '${validator_result}' == 'FAIL'
                Take Screenshot    Fail
            END
        END       
        IF    '${Stage_value}' == 'Minor Change'
            User navigated to the Case Listing module under Case Management               
            ${validator_result}    ${validator_error}=    Run Keyword And Ignore Error    Auto-calc PULSE-CDDR18 Minor Change    ${Title_value}    ${First_Name_value}    ${Middle_Name_value}    ${Last_Name_value}    ${Street_value}    ${City_value}    ${State_value}    ${County_value}    ${Postal_Code_value}    ${Country_value}    ${Telephone_value}    ${Telephone_Residence_value}    ${Email_Id_value}    ${Qualification_value}    ${Stage_value}
            IF    '${validator_result}' == 'FAIL'
                Take Screenshot    Fail
            END
        END                  
        ${Output_excel}=    Set Variable    ${EXECDIR}/Output/${sheet_name}.xlsx
        Update Cell By Excel Row    ${EXECDIR}/Output/${sheet_name}.xlsx    ${sheet_name}    ${row_index}    RCT No    ${RCT_No}
        Update Cell By Excel Row    ${Output_excel}    ${sheet_name}    ${row_index}    Actual Test Result    ${validator_result}
        ${row_index}=    Evaluate    ${row_index} + 1    
    END
    Set Test Variable    ${Output_excel}    
     Validate Test Results    ${Output_excel}

