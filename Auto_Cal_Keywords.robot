Get Data From Excel Sheet for Auto-calc Pulse-CDDR54
    [Documentation]    Validate Pulse-CDDR54    
    [Arguments]    ${sheet_name}
    ${project_folder}=    Set Variable    ${EXECDIR}${/}Resource${/}TestData_Excels${/}
    ${excel_file}=    Set Variable    ${project_folder}LSMV_TestData.xlsx
    ${sheet_name}=    Set Variable    ${sheet_name}
    ${data}=    Connect And Read Data From Excel Sheet    ${excel_file}    ${sheet_name}
    Log to Console  ${data}
    ${row_index}=    Set Variable    1
    FOR    ${row}    IN    @{data}
        Set Test Variable    ${JSON_File_value}    ${row['Json File']}
        Set Test Variable    ${company_unit_value}    ${row['company_unit']}
        Set Test Variable    ${latest_received_date_value}    ${row['Latest_received_date']}
        Set Test Variable    ${sender_organisation_value}    ${row['Sender Organization']}
        Set Test Variable    ${report_type_value}      ${row['Report_type']}
        Set Test Variable    ${investigation_number_value}    ${row['Investigation Number']}        
        Set Test Variable    ${patient_initial_value}    ${row['Patient Initial']}
        Set Test Variable    ${expected_investigation_number_value}    ${row['Excepted_Investigation Number']}
        Set Test Variable    ${expected_patient_initial_value}      ${row['Excepted_Patient Initial']}
        Set Test Variable    ${validation}      ${row['Validation']}
        
        IF    '${validation}' == 'Check 1'
            ${validator_result}    ${validator_error}=    Run Keyword And Ignore Error    Validate CDDR54 scenario one in Intake and Assignment Stage
            IF    '${validator_result}' == 'FAIL'
                Take Screenshot    Fail
            END    
        END
        IF    '${validation}' == 'Check 2'
            ${validator_result}    ${validator_error}=    Run Keyword And Ignore Error    Validate CDDR54 scenario two in Intake and Assignment Stage
            IF    '${validator_result}' == 'FAIL'
                Take Screenshot    Fail
            END    
        END        
        IF    '${validation}' in ['Check 5', 'Check 6']
            The User navigates to the Case Listing module under Case Management
            ${validator_result}    ${validator_error}=    Run Keyword And Ignore Error    Validate CDDR54 scenario six in Intake and Assignment Stage
            IF    '${validator_result}' == 'FAIL'
                Take Screenshot    Fail
            END    
        END
        Log    Validation Passed for Row: ${row_index}     console=True        
        ${Output_excel}=    Set Variable    ${EXECDIR}/Output/${sheet_name}.xlsx
        Update Cell By Excel Row    ${EXECDIR}/Output/${sheet_name}.xlsx    ${sheet_name}    ${row_index}    RCT No    ${RCT_No}
        Update Cell By Excel Row   ${Output_excel}    ${sheet_name}    ${row_index}    Actual Test Result    ${validator_result}
        ${row_index}=    Evaluate    ${row_index} + 1        
    END    
    Set Test Variable    ${Output_excel}    
    Validate Test Results    ${Output_excel}

