        Set Test Variable    ${product_two_expected_term}           ${row['Product Two Expected Term']}
        Set Test Variable    ${product_three_expected_term}         ${row['Product Three Expected Term']}
        Set Test Variable    ${workflow_value}                      ${row['Workflow']}
        Set Test Variable    ${result_value}                        ${row['Result']}
        IF   '${testnumber}' == 'Case 2'
           ${validator_result}    ${validator_error}=    Run Keyword And Ignore Error    threeproduct_Autocalc_PULSE-CDDR13    ${product_description_value}    ${product_flag_value}   ${product_characterization_one}   ${product_characterization_two}   ${product_characterization_three}   ${primary_source_country_value}   ${product_one_expected_term}   ${product_two_expected_term}   ${product_three_expected_term}   ${workflow_value}   ${result_value}
        END
        IF    '${validator_result}' == 'FAIL'
            Take Screenshot    Fail
        END
        Log Test Iteration Result To PDF    ${workflow_value}    ${validator_result}
        ${Output_excel}=    Set Variable    ${EXECDIR}/Output/${sheet_name}.xlsx
        Update Cell By Excel Row    ${EXECDIR}/Output/${sheet_name}.xlsx    ${sheet_name}    ${row_index}    RCT No    ${RCT_No}
        Update Cell By Excel Row    ${Output_excel}    ${sheet_name}    ${row_index}    Actual Test Result    ${validator_result}
        ${row_index}=    Evaluate    ${row_index} + 1
        Run Keyword If    "${validator_error}" != ""    Log    Row ${row_index}: Error processing data - ${validator_error}    ERROR
        Run Keyword If    "${validator_error}" != ""    Continue For Loop
        Log    ${validator_result}
    END    
    Set Test Variable    ${Output_excel}    
    Validate Test Results    ${Output_excel}

