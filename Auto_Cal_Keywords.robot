    END
    Log    ${act_weeks}
    Log    ${exp_Gestational_Age_at_Event_value}
    IF    '${exp_Gestational_Age_at_Event_value}' == 'No Change'
        ${gestationalage_weeks}=    Run Keyword And Return Status    Should Not Be Equal As Strings    ${act_weeks}    ${exp_weeks}
