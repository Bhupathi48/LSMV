        ELSE
            ${success_present}=    Run Keyword And Return Status    Wait Until Element Is Visible    ${wvar('action_complete_success_btn_ok_xpath')}    10s
            Run Keyword If    ${success_present}    Exit For Loop
            Sleep    2s
        END
        ${attempt}=    Evaluate    ${attempt} + 1
