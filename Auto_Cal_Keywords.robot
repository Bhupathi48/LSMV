        Set Test Variable    ${Product_value}            ${row['Product']} 
        Set Test Variable    ${Report_Receiving_Medium_value}    ${row['Report Receiving Medium']}    
        Set Test Variable    ${Reported_Term_value}    ${row['E2B_Causality_Reported_Term']}
        Set Test Variable    ${Source_value}    ${row['E2B_Causality_Source']}
        Set Test Variable    ${Method_value}    ${row['E2B_Causality_Method']}    
        Set Test Variable    ${Result_value}    ${row['E2B_Causality_Result']}
        Set Test Variable    ${Work_Flow_value}            ${row['Work Flow']}

        IF    '${row_index}' == '1'
            Import AER data and retrieve RCT number    ${Json_File_value}
