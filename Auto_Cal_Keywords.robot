Calculate date from date Difference
    [Documentation]    Calculate the due date based on the date difference
    [Arguments]    ${Date_Difference_value}    ${Company_Received_Date_value}    ${Operation_Method_value}
    Click Element Custom    ${wvar('general_tab_xpath')}
    ${CaseDueDate_text_box_xpath}=    Replace String    ${wvar('common_date_input_field_xpath')}    replace    ${wvar('case_due_date_text')}
    ${Case_due_date_xpath}=    Replace String    ${wvar('span_common_date_input_field_xpath')}    replace    ${wvar('case_due_date_text')}
    Highlight WebElement    ${Case_due_date_xpath}
    Scroll Element Into View    ${CaseDueDate_text_box_xpath}
    Take Screenshot    selenium
    ${Case_due_date}=    Get Element Attribute   ${CaseDueDate_text_box_xpath}    title
    ${Actual_Date_Difference}=    Calculate Date Difference     ${Company_Received_Date_value}    ${Case_due_date}   
    Log    Date Difference: ${Actual_Date_Difference}     console=True    
    Log    Expected Date: ${Date_Difference_value}     console=True
    ${Status}=    Run Keyword And Return Status    Should Be Equal As Strings    ${Actual_Date_Difference}    ${Date_Difference_value}
    Run Keyword If    '${Status}' == "${True}"
    ...    Log To Console    Validation Pass. Actual Date Difference: ${Actual_Date_Difference} == Expected Difference: ${Date_Difference_value}
    ...  ELSE
    ...    Fail    Validation Failed. Actual Date Difference: ${Actual_Date_Difference} != Expected Difference: ${Date_Difference_value}    

