        Set Test Variable    ${product_flag_value}                  ${row['Product flag']}
        Set Test Variable    ${product_characterization_one}        ${row['Product Characterization Product One']}
        Set Test Variable    ${product_characterization_two}        ${row['Product Characterization Product Two']}
        Set Test Variable    ${product_characterization_three}      ${row['Product Characterization Product Three']}
        Set Test Variable    ${primary_source_country_value}        ${row['Primary Source Country']}
