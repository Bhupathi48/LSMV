        Set Test Variable  ${Expected_Prod_Three_Brand_Name}  ${row['Expected Prod Three Brand Name']}
        Set Test Variable  ${Expected_Prod_Four_Brand_Name}  ${row['Expected Prod Four Brand Name']}
        Set Test Variable  ${Workflow}                       ${row['Workflow']}
        Set Test Variable  ${Activity}                       ${row['Activity']}
        IF    '${Workflow}' == 'Case Deletion'
            ${validator_result}    ${validator_error}=    Run Keyword And Ignore Error    Valdiate PULSE-CDDR132 In Case Deletion        ${json_file_name}    ${Product_One_Characterization}    ${Product_Two_Characterization}    ${Product_Three_Characterization}    ${Product_Four_Characterization}    ${Product_One_Brand_Name}    ${Product_Two_Brand_Name}    ${Product_Three_Brand_Name}    ${Product_Four_Brand_Name}    ${Product_One_Flag}    ${Product_Two_Flag}    ${Product_Three_Flag}  ${Product_Four_Flag}  ${Expected_Prod_One_Brand_Name}    ${Expected_Prod_Two_Brand_Name}    ${Expected_Prod_Three_Brand_Name}    ${Expected_Prod_Four_Brand_Name}    ${Workflow}    ${Activity}
