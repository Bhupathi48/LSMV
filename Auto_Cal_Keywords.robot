        Set Test Variable  ${Product_One_Characterization}       ${row['Product One Product Characterization']}
        Set Test Variable  ${Product_Two_Characterization}       ${row['Product Two Product Characterization']}
        Set Test Variable  ${Product_Three_Characterization}     ${row['Product Three Product Characterization']}
        Set Test Variable  ${Product_Four_Characterization}      ${row['Product Four Product Characterization']}
