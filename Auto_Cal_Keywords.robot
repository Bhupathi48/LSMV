Get Data From Excel Sheet for Auto-calc Pulse-CDDR60
    [Documentation]    Validate Pulse-CDDR60
    [Arguments]    ${sheet_name}
    ${project_folder}=    Set Variable    ${EXECDIR}${/}Resource${/}TestData_Excels${/}
    ${excel_file}=    Set Variable    ${project_folder}LSMV_TestData.xlsx
    ${sheet_name}=    Set Variable    ${sheet_name}
    ${data}=    Connect And Read Data From Excel Sheet    ${excel_file}    ${sheet_name}
    Log to Console  ${data}
    ${row_index}=    Set Variable    1
    FOR    ${row}    IN    @{data}
        Set Test Variable    ${company_unit_text_value}    ${row['Company Unit']}
        Set Test Variable    ${processing_unit_text_value}            ${row['Processing Unit']}
        Set Test Variable    ${report_type_text_value}            ${row['Report Type']}
        Set Test Variable    ${expected_processing_unit_value}            ${row['Expected Processing Unit']}
        ${RCT_No}=    Create Basic RCT for PULSE CDDR-60
        User navigated to the Case Listing module under Case Management   
        Search for AER    ${RCT_No}
        Wait Until Element Is Visible    ${wvar('processing_unit_label_xpath')}   timeout=20
        Highlight WebElement    ${wvar('company_unit_dropdown_xpath')}
        Highlight WebElement    ${wvar('processing_unit_dropdown_xpath')}
        ${actual_processing_unit_value}=    Get Text    ${wvar('processing_unit_dropdown_xpath')}
        Take Screenshot    selenium
        ${validator_result}    ${validator_error}=    Run Keyword And Ignore Error    Should Be Equal As Strings    ${actual_processing_unit_value}    ${expected_processing_unit_value}
        IF    '${validator_result}' == 'FAIL'
            Take Screenshot    Fail
        END
        Log    Validation Passed for Row: ${row_index}     console=True
        ${Output_excel}=    Set Variable    ${EXECDIR}/Output/${sheet_name}.xlsx
        Update Cell By Excel Row    ${EXECDIR}/Output/${sheet_name}.xlsx    ${sheet_name}    ${row_index}    RCT No    ${RCT_No}
        Update Cell By Excel Row    ${Output_excel}    ${sheet_name}    ${row_index}    Actual Test Result    ${validator_result}
        ${row_index}=    Evaluate    ${row_index} + 1
        User navigates to New Full Data Entry Form under Case Management
    END
    # Log file to report     ${Output_excel}
    # ${Test_Result}     ${Test_status}=    Get Actual Test Results    ${Output_excel}
    # Run Keyword If    '${Test_status}' == 'True'
    # ...    Log To Console    Test Pass.
    # ...  ELSE
    # ...    Fail    Test failed. Failure Test Data ${Test_Result}
    # Run Keyword If    '${test_status}' == 'Fail'    Fail    Test failed.
    Set Test Variable    ${Output_excel}    
    Validate Test Results    ${Output_excel}

