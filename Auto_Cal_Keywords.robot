Excel validation
    [Documentation]    Validate Excel data with highlighted products
    [Arguments]   ${prod_details}
    ${project_folder}=    Set Variable    ${EXECDIR}${/}Resource${/}TestData_Excels${/}
    ${excel_file}=    Set Variable    ${project_folder}LSMV_TestData.xlsx
    ${sheet_name}=    Set Variable    ${scenario_sheet_name}
    ${data}=    Connect And Read Data From Excel Sheet    ${excel_file}    ${sheet_name}
    ${row_index}=    Set Variable    1    
    FOR    ${row}    IN    @{data}
        Log    Product Name: ${row['Product name']} | Expected Indication term: ${row['Expected Indication Term']} 
        Set Test Variable    ${prod_name}      ${row['Product name']}
        Set Test Variable    ${expected}      ${row['Expected Indication Term']}
        Set Test Variable    ${workflow}      ${row['Workflow']}
        Set Test Variable    ${s_no}      ${row['Sl. No']}
        
        ${actual_value}=    Get From Dictionary   ${prod_details}   ${prod_name}    default=
        Log    Actual Value: ${actual_value}
        ${result_status}=    Run Keyword And Return Status    Should Be Equal As Strings    ${actual_value}    ${expected}
            IF   '${result_status}' == 'True'
                ${result}=  Set variable    PASS
            ELSE
                ${result}=  Set variable    FAIL
            END

    Log Test Iteration Result To PDF    ${workflow} Review    ${result}
    ${Output_excel}=    Set Variable    ${EXECDIR}/Output/${sheet_name}.xlsx
    Update Cell By Excel Row    ${Output_excel}    ${sheet_name}    ${row_index}    RCT No    ${rct_number_json}
    Update Cell By Excel Row   ${Output_excel}    ${sheet_name}    ${row_index}    Actual Test Result    ${result}
    ${row_index}=    Evaluate    ${row_index} + 1
    END
    Set Test Variable    ${Output_excel}    
    Validate Test Results    ${Output_excel}


