Validate Pulse-CDDR-23 
    [Documentation]     Validate Pulse-CDDR-20 For Final Review
    ${project_folder}=    Set Variable    ${EXECDIR}${/}Resource${/}TestData_Excels${/}
    ${excel_file}=    Set Variable    ${project_folder}LSMV_TestData.xlsx
    ${sheet_name}=    Set Variable    ${scenario_sheet_name}
    ${data}=    Connect And Read Data From Excel Sheet    ${excel_file}    ${sheet_name}
    Log to Console  ${data}
    ${row_index}=    Set Variable    1
    FOR    ${row}    IN    @{data}        
        Set Test Variable    ${Report_Type_value}    ${row['Report Type']}
        Set Test Variable    ${Study_Type_value}    ${row['Study Type']}
        Set Test Variable    ${Event_Type_value}      ${row['Event Type']}   
        Set Test Variable    ${Report_Causality_value}      ${row['Report Causality']} 
        Set Test Variable    ${Company_Causality_value}      ${row['Company Causality']}
        Set Test Variable    ${Product_Characterization_value}      ${row['Product Characterization']} 
        Set Test Variable    ${labeling1_ctry_value}      ${row['labeling Country 1']} 
        Set Test Variable    ${label1_value}      ${row['label1']}  
        Set Test Variable    ${labeling2_ctry_value}      ${row['labeling Country 2']} 
        Set Test Variable    ${label2_value}      ${row['label2']}
        Set Test Variable    ${Pre_Check_IB_SUSAR_Flag}      ${row['IB SUSAR Flag']}  
        Set Test Variable    ${Pre_Check_EU_SUSAR_Flag}      ${row['EU SUSAR Flag']}
        Set Test Variable    ${Pre_Check_General_SUSAR_Status}      ${row['General SUSAR Flag']}   
        Set Test Variable    ${Expected_IB_SUSAR_Flag}      ${row['Expected IB SUSAR Flag']}                  
        Set Test Variable    ${labeling_SUSAR_Status_value}      ${row['Expected EU SUSAR Flag']}              
        Set Test Variable    ${general_SUSAR_Status_value}      ${row['Expected General SUSAR Flag']}              
        ${validator_result}    ${validator_error}=    Run Keyword And Ignore Error    Validate Precondition for Pulse-CDDR-23       ${Report_Type_value}    ${Study_Type_value}    ${Event_Type_value}    ${Report_Causality_value}    ${Company_Causality_value}    ${Product_Characterization_value}    ${labeling1_ctry_value}    ${label1_value}    ${labeling2_ctry_value}    ${label2_value}    ${labeling_SUSAR_Status_value}    ${general_SUSAR_Status_value}    ${Pre_Check_IB_SUSAR_Flag}     ${Pre_Check_EU_SUSAR_Flag}    ${Pre_Check_General_SUSAR_Status}          
        IF    '${validator_result}' == 'FAIL'
            Take Screenshot    Fail
        END                       
        ${Output_excel}=    Set Variable    ${EXECDIR}/Output/${sheet_name}.xlsx
        Update Cell By Excel Row    ${EXECDIR}/Output/${sheet_name}.xlsx    ${sheet_name}    ${row_index}    RCT No    ${RCT_No}
        Update Cell By Excel Row    ${Output_excel}    ${sheet_name}    ${row_index}    Actual Test Result    ${validator_result}
        ${row_index}=    Evaluate    ${row_index} + 1    
    END
    Set Test Variable    ${Output_excel}    
    Validate Test Results    ${Output_excel}

