        Set Test Variable    ${Json_File_value}    ${row['Json File']}                     
        Set Test Variable    ${Event_two_Onset_date_value}    ${row['Event_2_Onset_date']}
        Set Test Variable    ${Event_two_cessation_date_value}    ${row['Event_2_Cessation_date']}     
