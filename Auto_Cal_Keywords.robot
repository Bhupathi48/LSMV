Get Data From Excel Sheet for Auto-calc Pulse-CDDR109
    [Documentation]    Validate Pulse-CDDR109
    [Arguments]    ${sheet_name}
    ${project_folder}=    Set Variable    ${EXECDIR}${/}Resource${/}TestData_Excels${/}
    ${excel_file}=    Set Variable    ${project_folder}LSMV_TestData.xlsx
    ${sheet_name}=    Set Variable    ${sheet_name}
    # Search for RCT Latest    RCT20250065163
    # Minor change activity for CDDR109    02-02-2020    Test    Asked but Unknown
    ${data}=    Connect And Read Data From Excel Sheet    ${excel_file}    ${sheet_name}
    Log to Console  ${data}
    ${row_index}=    Set Variable    1
    FOR    ${row}    IN    @{data}
        Set Test Variable    ${Json_File_value}            ${row['Json']}
        Set Test Variable	${parent_id}	${row['Parent id']}
        Set Test Variable	${parent_dob}	${row['Parent dob']}
        Set Test Variable	${parent_age}	${row['Parent age']}
        Set Test Variable	${parent_age_unit}	${row['Parent age unit']} 
        Set Test Variable	${parent_lmp}	${row['LMP of parent']}
        Set Test Variable	${parent_weight}	${row['Parent weight']}
        Set Test Variable    ${expected_value}   ${row['Expected Parent Gender']} 
        Set Test Variable    ${comments}   ${row['Comments']} 
        Set Test Variable    ${start_date}   ${row['start date']} 
        ${formatted_start_date}=    Convert Date    ${start_date}    result_format=%d-%b-%Y
        IF    '${row_index}' == '1'
            RCT Creation and move to FR stage    ${Json_File_value}  
        END
        IF    '${row_index}' == '2'
            ${validator_result}    ${validator_error}=    Run Keyword And Ignore Error    Minor change activity for CDDR109     ${formatted_start_date}    ${comments}    ${expected_value}
        ELSE
           ${validator_result}    ${validator_error}=    Run Keyword And Ignore Error    Validate Auto-calc PULSE-CDDR109    ${parent_id}    ${parent_dob}    ${parent_age}   ${parent_lmp}    ${parent_weight}    ${expected_value}
        END
            
        
        IF    '${validator_result}' == 'FAIL'
            Take Screenshot    Fail
        END
        Log    Validation Passed for Row: ${row_index}     console=True
        ${Output_excel}=    Set Variable    ${EXECDIR}/Output/${sheet_name}.xlsx
        Update Cell By Excel Row    ${Output_excel}    ${sheet_name}    ${row_index}    RCT No    ${rct_number_json}
        Update Cell By Excel Row    ${Output_excel}    ${sheet_name}    ${row_index}    Actual Test Result    ${validator_result}
        ${row_index}=    Evaluate    ${row_index} + 1
        Set Test Variable    ${row_index}    ${row_index}
    END
    # Log file to report     ${Output_excel}
    # ${Test_Result}     ${Test_status}=    Get Actual Test Results    ${Output_excel}
    # Run Keyword If    '${Test_status}' == 'True'
    # ...    Log To Console    Test Pass.
    # ...  ELSE
    # ...    Fail    Test failed. Failure Test Data ${Test_Result}
    # Run Keyword If    '${test_status}' == 'Fail'    Fail    Test failed because parent gender not populated as expected.
    Set Test Variable    ${Output_excel}    
     Validate Test Results    ${Output_excel}

