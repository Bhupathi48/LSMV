    Log to Console  ${data}
    ${row_index}=    Set Variable    1
    FOR    ${row}    IN    @{data}
        Set Test Variable    ${Expected_Sender_Organization}    ${row['Sender Organization']}
        Set Test Variable    ${Expected_Authority_No_Comp_Number}    ${row['Expected Authority No/Comp Number']}
        Set Test Variable    ${Expected_Source}    ${row['Expected Source']}
        Set Test Variable    ${Expected_Reference_Type}    ${row['Expected Reference Type']}
        Set Test Variable    ${File_Name_Or_RCT}    ${row['File Name/Receipt No']}
    
        IF    '${row_index}' < '3'
            IF    '${row_index}' == '2'
                User navigated to the Case Listing module under Case Management
            END
            Create RCT for Pulse-CDDR59    ${File_Name_Or_RCT}
        ELSE
            User navigated to the Case Listing module under Case Management
            Navigate to Complaint Management and Select RCT   ${File_Name_Or_RCT}
        END
        ${validator_result}    ${validator_error}=    Run Keyword And Ignore Error    Validate Auto-calc PULSE-CDDR59     ${Expected_Sender_Organization}    ${Expected_Authority_No_Comp_Number}    ${Expected_Source}    ${Expected_Reference_Type}
        IF    '${validator_result}' == 'FAIL'
            Take Screenshot    Fail
        END
        Log    Validation Passed for Row: ${row_index}     console=True
        ${Output_excel}=    Set Variable    ${EXECDIR}/Output/${sheet_name}.xlsx
        IF    '${row_index}' < '3'
            Update Cell By Excel Row    ${EXECDIR}/Output/${sheet_name}.xlsx    ${sheet_name}    ${row_index}    Expected Reference Number    ${Expected_Reference_Number}
        END
        IF    '${row_index}' == '3'
            ${RCT_No}=    Set Variable    ${File_Name_Or_RCT}
            Update Cell By Excel Row    ${EXECDIR}/Output/${sheet_name}.xlsx    ${sheet_name}    ${row_index}    Expected Authority No/Comp Number    ${Authority_No_Comp_Number}
        END
        Update Cell By Excel Row    ${EXECDIR}/Output/${sheet_name}.xlsx    ${sheet_name}    ${row_index}    Authority No/Comp Number    ${Authority_No_Comp_Number}
        Update Cell By Excel Row    ${EXECDIR}/Output/${sheet_name}.xlsx    ${sheet_name}    ${row_index}    RCT No    ${RCT_No}
        Update Cell By Excel Row    ${Output_excel}    ${sheet_name}    ${row_index}    Actual Test Result    ${validator_result}
        ${row_index}=    Evaluate    ${row_index} + 1
    END
    Set Test Variable    ${Output_excel}    
    Validate Test Results    ${Output_excel}

