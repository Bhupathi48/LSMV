            Navigate to Complaint Management and Select RCT   ${rct_number_json}
            Move to Causality Tab    ${Report_Receiving_Medium_value}
        END
         
        ${validator_result}    ${validator_error}=    Run Keyword And Ignore Error    Validate Auto-calc PULSE-CDDR46     ${Report_Receiving_Medium_value}    ${Reported_Term_value}    ${Source_value}    ${Method_value}    ${Result_value}    ${Work_Flow_value}    ${Table_Index_value}    ${Product_value}    ${row_index}
        IF    '${validator_result}' == 'FAIL'
            Take Screenshot    Fail
        END

        Log    Validation Passed for Row: ${row_index}     console=True        
        ${Output_excel}=    Set Variable    ${EXECDIR}/Output/${sheet_name}.xlsx
        Update Cell By Excel Row    ${EXECDIR}/Output/${sheet_name}.xlsx    ${sheet_name}    ${row_index}    RCT No    ${rct_number_json}
        Update Cell By Excel Row   ${Output_excel}    ${sheet_name}    ${row_index}    Actual Test Result    ${validator_result}
        ${row_index}=    Evaluate    ${row_index} + 1        
    END
    Log file to report     ${Output_excel}
    ${Test_Result}     ${Test_status}=    Get Actual Test Results    ${Output_excel}
    Run Keyword If    '${Test_status}' == 'True'
    ...    Log To Console    Test Pass.
    ...  ELSE
    ...    Fail    Test failed. Failure Test Data ${Test_Result}
    Run Keyword If    '${Test_status}' == 'Fail'    Fail    Test failed due to workflow status mismatch.
