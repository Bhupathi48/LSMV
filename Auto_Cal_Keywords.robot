Get Data From Excel Sheet for Auto-calc Pulse-CDDR77
    [Documentation]    Validate Pulse-CDDR77
    [Arguments]    ${sheet_name}
    ${project_folder}=    Set Variable    ${EXECDIR}${/}Resource${/}TestData_Excels${/}
    ${excel_file}=    Set Variable    ${project_folder}LSMV_TestData.xlsx
    ${sheet_name}=    Set Variable    ${sheet_name}
    ${data}=    Connect And Read Data From Excel Sheet    ${excel_file}    ${sheet_name}
    Log to Console  ${data}
    ${row_index}=    Set Variable    1
    FOR    ${row}    IN    @{data}        

        Set Test Variable    ${Sender_Organization_Value}    ${row['Sender_Organization']} 
        Set Test Variable    ${Company_Unit_Value}    ${row['Company_Unit']} 
        Set Test Variable    ${Sponsor_Study_No_Value}    ${row['Sponsor_Study_No']}
        Set Test Variable    ${Sponsor_Study_Value}    ${row['Study_type']} 
        Set Test Variable    ${Report_Type_Value}    ${row['Report_Type']}
        Set Test Variable    ${Event_No_value}    ${row['Event_No']}
        Set Test Variable    ${Product_Characterization_Value}    ${row['Product_Characterization']} 
        Set Test Variable    ${Product_Description_Value}    ${row['Product_Description']} 
        Set Test Variable    ${Expected_labeling_Country_Value}    ${row['Expected_labeling_Country']}   
        Set Test Variable    ${Work_Flow_Value}            ${row['Work Flow']}

        IF    '${row_index}' != '1'
            User navigates to New Full Data Entry Form under Case Management
        END

        ${validator_result}    ${validator_error}=    Run Keyword And Ignore Error    Validate Auto-calc PULSE-CDDR77     ${Sender_Organization_Value}    ${Company_Unit_Value}    ${Report_Type_Value}    ${Product_Characterization_Value}    ${Product_Description_Value}    ${Expected_labeling_Country_Value}    ${Work_Flow_Value}    ${Sponsor_Study_No_Value}    ${Sponsor_Study_Value}    ${Event_No_value}
        IF    '${validator_result}' == 'FAIL'
            Take Screenshot    Fail
        END
        Log    Validation Passed for Row: ${row_index}     console=True        
        ${Output_excel}=    Set Variable    ${EXECDIR}/Output/${sheet_name}.xlsx
