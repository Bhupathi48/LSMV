    FOR    ${row}    IN    @{data}
        Log    Start Date Format: ${row['Start Date Format']} | End Date Format: ${row['End Date Format']} | Condition: ${row['Condition']} | Value: ${row['Date Difference']} | Result: ${row['Expected Result']}
        Set Test Variable    ${caused_prolonged_hospital_value}    ${row['Caused/prolonged hospitalization']}
        Set Test Variable    ${hospitalization_required_value}      ${row['Hospitalization Required(in case of Vaccine)']}
