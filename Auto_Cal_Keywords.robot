        ${validator_result}    ${validator_error}=    Run Keyword And Ignore Error    Validate Auto-calc PULSE-CDDR56     ${Sender_Organization_value}    ${Primary_Source_country_value}    ${Reporter_Country_value}    ${Expected_Reporter_Country_value}    ${Work_Flow_value_stripped}    ${Work_Flow_Stage_value}
        IF    '${validator_result}' == 'FAIL'
            Take Screenshot    Fail
        END
        Log    Validation Passed for Row: ${row_index}     console=True        
