        Set Test Variable    ${Event_one_value}    ${row['Event1']}
        Set Test Variable    ${Event_two_value}    ${row['Event2']}               
        
        IF    '${validation}' in ['Check 1', 'Check 2']
            ${validator_result}    ${validator_error}=    Run Keyword And Ignore Error    Validate CDDR41 in Final Review Stage
            IF    '${validator_result}' == 'FAIL'
                Take Screenshot    Fail
            END    
        END
        IF    '${validation}' in ['Check 3', 'Check 4']
