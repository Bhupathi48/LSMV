Validate Validator-0033 where Validation should fire when a case has been advanced from Medical Review to Supplemental Review
    [Documentation]      Driver keyword for PULSE_003_NEW based on case version and workflow
    ${project_folder}=    Set Variable    ${EXECDIR}${/}Resource${/}TestData_Excels${/}
    ${excel_file}=    Set Variable    ${project_folder}LSMV_TestData.xlsx
    ${sheet_name}=    Set Variable    ${scenario_sheet_name}
    ${data}=    Connect And Read Data From Excel Sheet    ${excel_file}    ${sheet_name}
    Log to Console  ${data}
    ${row_index}=    Set Variable    1    
    FOR    ${row}    IN    @{data}
        Set Test Variable    ${case_version}   ${row['Case version']}
        Set Test Variable    ${workflow}   ${row['Workflow']}
        Set Test Variable    ${expected_result}   ${row['Expected Result']}
        Set Test Variable    ${validation}   ${row['Validation']}
        ${validator_result}    ${validator_error}=    Run Keyword And Ignore Error    Validate PULSE-0033 Case Version And Workflow    ${case_version}    ${workflow}    ${expected_result}    ${validation}
        ${Output_excel}=    Set Variable    ${EXECDIR}/Output/${sheet_name}.xlsx
