Get Data From Excel Sheet for Auto-calc Pulse-CDDR38
        [Documentation]    Validate Pulse-CDDR38
        [Arguments]    ${sheet_name}
        # ${project_folder}=    Set Variable    ${CURDIR}${/}..${/}
        ${project_folder}=    Set Variable    ${EXECDIR}${/}Resource${/}TestData_Excels${/}
        ${excel_file}=    Set Variable    ${project_folder}LSMV_TestData.xlsx
        ${sheet_name}=    Set Variable    ${sheet_name}
        ${data}=    Connect And Read Data From Excel Sheet    ${excel_file}    ${sheet_name}
        Log to Console  ${data}
        ${row_index}=    Set Variable    1
        FOR    ${row}    IN    @{data}        

            Set Test Variable    ${Sender_Organization_Value}    ${row['Sender Organization']} 
            Set Test Variable    ${jsonfile}    ${row['Json File']}
            Set Test Variable    ${Manual_Value}    ${row['Manual']}   
            Set Test Variable    ${Case_Significance_Value}    ${row['Case Significance']}
            Set Test Variable    ${Expected_Case_Significance_Value}    ${row['Expected Case Significance']}
            Set Test Variable    ${Expected_Manual_Value}    ${row['Expected Manual']}    
            Set Test Variable    ${Work_Flow_Value}            ${row['Workflow']}
            Set Test Variable    ${Work_Flow_Stage_Value}    ${row['Activity ']}
    
            IF    '${row_index}' != '0'
                User navigated to the Case Listing module under Case Management   
                Wait for Element display
                ${AER_No}=    Create RCT And Move To Distribute Transit Stage And Return AER No
                Wait For Element Display
                ${RCT_No}=    Upload AER Data    ${EXECDIR}/Resource/Json/${jsonfile}    
                Set Test Variable    ${RCT_No}     
                Search for RCT Latest    ${RCT_No}  
                Wait For General Tab
                Create Followup    ${AER_No}
                Wait for Element display
                Click element custom    ${wvar('case_information_xpath')}
                
            END

            ${validator_result}    ${validator_error}=    Run Keyword And Ignore Error    Validate Auto-calc PULSE-CDDR38     ${Sender_Organization_Value}    ${Manual_Value}    ${Case_Significance_Value}    ${Expected_Case_Significance_Value}    ${Expected_Manual_Value}    ${Work_Flow_Value}    ${Work_Flow_Stage_Value}
            IF    '${validator_result}' == 'FAIL'
                Take Screenshot    Fail
            END
            Log    Validation Passed for Row: ${row_index}     console=True        
            ${Output_excel}=    Set Variable    ${EXECDIR}/Output/${sheet_name}.xlsx
            Update Cell By Excel Row    ${EXECDIR}/Output/${sheet_name}.xlsx    ${sheet_name}    ${row_index}    RCT No    ${RCT_No}
            Update Cell By Excel Row   ${Output_excel}    ${sheet_name}    ${row_index}    Actual Test Result    ${validator_result}
            ${row_index}=    Evaluate    ${row_index} + 1        
        END
        Log file to report     ${Output_excel}
        ${Test_Result}     ${Test_status}=    Get Actual Test Results    ${Output_excel}
        Run Keyword If    '${Test_status}' == 'True'
        ...    Log To Console    Test Pass.
        ...  ELSE
        ...    Fail    Test failed. Failure Test Data ${Test_Result}
        Run Keyword If    '${Test_status}' == 'Fail'    Fail    Test failed due to workflow status mismatch.
    

