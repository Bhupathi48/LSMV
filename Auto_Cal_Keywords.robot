        Set Test Variable    ${Date_Difference_value}      ${row['Date Difference']}
        Set Test Variable    ${result_output_value}               ${row['Expected Output']}
        Set Test Variable    ${result_value}               ${row['Expected Result']}
        #Auto-calc PULSE-CDDR28    ${caused_prolonged_hospital_value}    ${hospitalization_required_value}    ${Start_Date_format_value}    ${End_Date_format_value}   ${Condition_value}   ${Date_Difference_value}      ${result_output_value}   ${result_value}
