    Log to Console  ${data}
    ${row_index}=    Set Variable    1
    FOR    ${row}    IN    @{data}        
        Set Test Variable    ${Json_File_value}    ${row['Json File']}   
        Set Test Variable    ${Sender_Organization_value}    ${row['Sender Organization']}    
        Set Test Variable    ${Primary_Source_country_value}    ${row['Primary Source country']}
