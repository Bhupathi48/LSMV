Get Data From RCT Excel Sheet for Auto-calc PULSE-CDDR11_1
    [Documentation]    Validate Lot_No field is UnKnown when the therapy is Blank in the initial workflow
    [Arguments]    ${sheet_name}
    ${project_folder}=    Set Variable    ${EXECDIR}${/}Resource${/}TestData_Excels${/}
    ${excel_file}=    Set Variable    ${project_folder}LSMV_TestData.xlsx
    ${sheet_name}=    Set Variable    ${sheet_name}
    ${data}=    Connect And Read Data From Excel Sheet    ${excel_file}    ${sheet_name}
    Log     ${data}
    ${row_index}=    Set Variable    1
    ${check1_passed}=    Set Variable    False
    Set Test Variable    ${RCT_No}    N/A
    
    FOR    ${row}    IN    @{data}
        Set Test Variable    ${company_unit_value}    ${row['Company_Unit']}
        Set Test Variable    ${sender_organisation_value}    ${row['Sender Organization']}
        Set Test Variable    ${Latest_received_date_value}      ${row['Latest_received_date']}
        Set Test Variable    ${Report_type_value}    ${row['Report_type']}
#        Set Test Variable    ${primary_source_country_val}    ${row['Primary_source_country']}
        Set Test Variable    ${product_descrip_value}    ${row['Product Name']} 
        Set Test Variable    ${product_characterization_value}    ${row['Product Charaterization']}      
        # Set Test Variable    ${Date}    ${row['Therapy_start_date']}
        Set Test Variable    ${Therapy_1_value}    ${row['Therapy1 Lot/Batch No']}
        Set Test Variable    ${Therapy_2_value}    ${row['Therapy2 Lot/Batch No']}
        Set Test Variable    ${validation}      ${row['Validation']}
        IF    '${validation}' in ['Check 1', 'Check 6']                
            ${validator_result}    ${validator_error}=    Run Keyword And Ignore Error    Validate CDDR-11_1
            IF    '${validator_result}' == 'FAIL'
                Take Screenshot    Fail
            END
        END
        IF    '${validation}' in ['Check 2', 'Check 3', 'Check 4', 'Check 5', 'Check 7', 'Check 8', 'Check 9', 'Check 10']
            ${validator_result}    ${validator_error}=    Run Keyword And Ignore Error    filling therapys for CDDR11_1 for pulse11
            IF    '${validator_result}' == 'FAIL'
                Take Screenshot    Fail 
            END
        END
        #Log Test Iteration Result To PDF    ${result_value}    ${validator_result}
        ${Output_excel}=    Set Variable    ${EXECDIR}/Output/${sheet_name}.xlsx
        ${rct_exists}=    Run Keyword And Return Status    Variable Should Exist    ${RCT_No}
        IF    ${rct_exists}
            Update Cell By Excel Row    ${EXECDIR}/Output/${sheet_name}.xlsx    ${sheet_name}    ${row_index}    RCT No    ${RCT_No}
        END
        Update Cell By Excel Row    ${Output_excel}    ${sheet_name}    ${row_index}    Actual Test Result    ${validator_result}
        ${row_index}=    Evaluate    ${row_index} + 1
    END    
    Set Test Variable    ${Output_excel}    
    Validate Test Results    ${Output_excel}

