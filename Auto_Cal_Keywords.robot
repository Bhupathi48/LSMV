Get Data From RCT Excel Sheet for Auto-calc PULSE-CDDR91
    [Documentation]    Get data from the project Excel sheet
    [Arguments]    ${sheet_name}
    Log    ${EXECDIR}
    Log    ${CURDIR}
    ${project_folder}=    Set Variable    ${EXECDIR}${/}Resource${/}TestData_Excels${/}
    ${excel_file}=    Set Variable    ${project_folder}LSMV_TestData.xlsx
    ${sheet_name}=    Set Variable    ${sheet_name}
    ${data}=    Connect And Read Data From Excel Sheet    ${excel_file}    ${sheet_name}
    Log to Console  ${data}
    ${row_index}=    Set Variable    1
    FOR    ${row}    IN    @{data}
        Set Test Variable    ${Parent_Medical_History_Start_Date}    ${row['Parent Medical History Start Date']}
        Set Test Variable    ${Parent_Medical_History_End_Date}      ${row['Parent Medical History End Date']}
        Set Test Variable    ${Duration}         ${row['Duration']}
        Set Test Variable    ${Duration_Unit}      ${row['Duration Unit']}
        Set Test Variable    ${Expected_Duration}       ${row['Expected Duration']}
        Set Test Variable    ${Expected_Duration_Unit}        ${row['Expected Duration Unit']}
        Select Parent Tab
        Enter Report Disease Term In Parent Tab    ${wvar('reported_disease_term')}
        Enter Disease Type In Parent Tab    ${wvar('past_condition_dd_title')}
        ${validator_result}    ${validator_error}=    Run Keyword And Ignore Error    Auto_Calc PULSE-CDDR91 Validation Logic    ${Parent_Medical_History_Start_Date}    ${Parent_Medical_History_End_Date}   ${Duration}   ${Duration_Unit}      ${Expected_Duration}      ${Expected_Duration_Unit}
        IF    '${validator_result}' == 'FAIL'
            Take Screenshot    Fail
        END        
        ${Output_excel}=    Set Variable    ${EXECDIR}/Output/${sheet_name}.xlsx
        Update Cell By Excel Row    ${EXECDIR}/Output/${sheet_name}.xlsx    ${sheet_name}    ${row_index}    RCT No    ${RCT_No}
        Update Cell By Excel Row    ${Output_excel}    ${sheet_name}    ${row_index}    Actual Test Result    ${validator_result}
        ${row_index}=    Evaluate    ${row_index} + 1
    END
    Set Test Variable    ${Output_excel}    
    Validate Test Results    ${Output_excel}     

